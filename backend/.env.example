# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database
DATABASE_URL=postgresql://foodbridge:password@localhost:5432/foodbridge
DB_HOST=localhost
DB_PORT=5432
DB_NAME=foodbridge
DB_USER=foodbridge
DB_PASSWORD=password
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_REFRESH_EXPIRES_IN=30d

# OTP
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_LOCKOUT_MINUTES=10

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_VERIFY_SERVICE_SID=your_verify_service_sid

# AWS S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=foodbridge-uploads
AWS_S3_BUCKET_DOCUMENTS=foodbridge-documents
AWS_CLOUDFRONT_URL=https://cdn.foodbridge.org

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=foodbridge-prod
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@foodbridge-prod.iam.gserviceaccount.com
FIREBASE_DATABASE_URL=https://foodbridge-prod.firebaseio.com

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3001,http://localhost:19006

# File Upload
MAX_FILE_SIZE_MB=10
MAX_PHOTOS_PER_LISTING=6

# Geospatial
DEFAULT_SEARCH_RADIUS_KM=5
MAX_SEARCH_RADIUS_KM=25

# Matching Engine
PROXIMITY_WEIGHT=0.4
URGENCY_WEIGHT=0.3
PREFERENCE_WEIGHT=0.2
CAPACITY_WEIGHT=0.1

# Claim System
CLAIM_ACCEPT_TIMEOUT_MINUTES=15
PICKUP_CODE_EXPIRY_HOURS=1
MAX_ACTIVE_CLAIMS_PER_USER=5

# Trust & Safety
MIN_RATING_THRESHOLD=2.5
AUTO_SUSPEND_RATING=2.5
AUTO_SUSPEND_MIN_RATINGS=10
MAX_CANCELLATIONS_PER_MONTH=3

# Notifications
MAX_PUSH_NOTIFICATIONS_PER_DAY=5
URGENT_LISTING_THRESHOLD_MINUTES=30

# Monitoring
SENTRY_DSN=your_sentry_dsn
LOG_LEVEL=info

# Admin
ADMIN_EMAIL=admin@foodbridge.org
ADMIN_PHONE=+919876543210
